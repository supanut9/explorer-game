# Allow routine local inspection commands without prompts.
prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Local repo status checks are safe and routine.",
    match = [
        "git status",
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Local diffs are safe and useful for review.",
    match = [
        "git diff",
        "git diff --stat",
    ],
)

prefix_rule(
    pattern = ["git", "branch"],
    decision = "allow",
    justification = "Branch inspection is safe and routine.",
    match = [
        "git branch",
        "git branch --show-current",
    ],
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "History inspection is safe and useful for planning.",
    match = [
        "git log",
        "git log --oneline -5",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
    justification = "Viewing PR metadata is a read-only remote operation.",
    match = [
        "gh pr view 123",
        "gh pr view 123 --json title,body",
    ],
)

prefix_rule(
    pattern = ["gh", "issue", "view"],
    decision = "allow",
    justification = "Viewing issue metadata is a read-only remote operation.",
    match = [
        "gh issue view 123",
    ],
)

# Prompt before remote-changing or write operations.
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing changes updates the remote repository.",
    match = [
        "git push",
        "git push origin sprint/05",
    ],
)

prefix_rule(
    pattern = ["git", ["fetch", "pull"]],
    decision = "prompt",
    justification = "Fetching or pulling updates local branch state from the remote.",
    match = [
        "git fetch",
        "git pull",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["create", "edit"]],
    decision = "prompt",
    justification = "Creating or editing a PR changes remote repository metadata.",
    match = [
        "gh pr create --fill",
        "gh pr edit 123 --title Update",
    ],
)

# Block destructive commands that conflict with repo policy.
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard work with `git reset --hard` in this repo.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "forbidden",
    justification = "Do not discard file changes with `git checkout --` in this repo.",
    match = [
        "git checkout -- AGENTS.md",
    ],
)

prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "Do not remove untracked files with `git clean -fd` in this repo.",
    match = [
        "git clean -fd",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Avoid destructive recursive deletes. Use explicit file edits instead.",
    match = [
        "rm -rf temp",
    ],
)
